{
	"version": "2.0.0",
	"tasks": [
		{
			/* Remove the intermediates directory obj/ and the output directory bin/. */
			"type": "shell",
			"label": "clean-cpp",
			"options": {
				"cwd": "${workspaceFolder}/build",
				// Empty "args" guarantees clean shell command.
				"shell": { "args": [] }
			},
			"presentation": {
				"clear": true,
				"reveal": "silent",
				"close": true
			},

			"command": "make",
			"args": ["clean"]
		},
		{
			"type": "shell",
			"label": "experiment-new",
			"options": {
				"cwd": "${workspaceFolder}/build",
				"shell": { "args": [] }
			},
			"presentation": {
				"clear": true,
				"reveal": "silent",
				"close": true
			},

			"command": "make",
			"args": [
				"new",
				"TYPE=experiment",
				"NAME=${input:experiment_new-name}"
			]
		},
		{
			"type": "shell",
			"label": "note-new",
			"options": {
				"cwd": "${workspaceFolder}/build",
				"shell": { "args": [] }
			},
			"presentation": {},

			"command": "make",
			"args": [
				"new",
				"TYPE=note",
				"NAME=${input:note_new-name}"
			]
		},
		{
			/* Build the open file in debug mode. */
			"type": "shell",
			"label": "build-debug-x64",
			"options": {
				"cwd": "${workspaceFolder}/build",
				"shell": { "args": [] }
			},
			"presentation": { "clear": true, "reveal": "never" },
			"group": { "kind": "build", "isDefault": true },

			"command": "make",
			"args": [
				"PROJ=${relativeFileDirname}",
				"BIN=${fileBasenameNoExtension}"
			],
			"problemMatcher": ["$codelldb-rustc"],
			"windows": { "problemMatcher": ["$msCompile"] }
		},
		{
			/* Build the open file in release mode. */
			"type": "shell",
			"label": "build-release-x64",
			"options": {
				"cwd": "${workspaceFolder}/build",
				"shell": { "args": [] }
			},
			"presentation": { "clear": true, "reveal": "never" },
			"group": "build",

			"command": "make",
			"args": [
				"PROJ=${relativeFileDirname}",
				"BIN=${fileBasenameNoExtension}",
				"BUILD=1"
			],
			"problemMatcher": ["$codelldb-rustc"],
			"windows": { "problemMatcher": ["$msCompile"] }
		}
	],
	"inputs": [
		{
			"id": "experiment_new-name",
			"description": "Name:",
			"default": "",
			"type": "promptString"
		},
		{
			"id": "note_new-name",
			"description": "Name:",
			"default": "",
			"type": "promptString"
		}
	]
}
